 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Exploratory Data Analysis: Credit Card Fraud Detection\n",
    "\n",
    "This notebook explores the Kaggle Credit Card Fraud dataset to understand feature distributions, class imbalances, and correlations before building our MLOps training pipeline."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "sns.set_theme(style=\"whitegrid\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Data Loading & Basic Info"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df = pd.read_csv('../data/raw/creditcard.csv')\n",
    "print(f\"Dataset Shape: {df.shape}\")\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df.info()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"Missing values in each column:\")\n",
    "print(df.isnull().sum().max()) # Should be 0"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Class Imbalance"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class_counts = df['Class'].value_counts()\n",
    "fraud_ratio = class_counts[1] / len(df)\n",
    "\n",
    "print(f\"Legitimate Transactions: {class_counts[0]}\")\n",
    "print(f\"Fraudulent Transactions: {class_counts[1]}\")\n",
    "print(f\"Fraud Ratio: {fraud_ratio:.4%}\")\n",
    "\n",
    "plt.figure(figsize=(6, 4))\n",
    "sns.countplot(data=df, x='Class', palette='Set2')\n",
    "plt.title('Class Distribution (0 = Legitimate, 1 = Fraud)')\n",
    "plt.yscale('log') # Log scale because of extreme imbalance\n",
    "plt.ylabel('Count (Log Scale)')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Feature Distributions (Time & Amount)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, ax = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "sns.histplot(df['Time'], bins=50, ax=ax[0], color='blue', kde=True)\n",
    "ax[0].set_title('Distribution of Transaction Time')\n",
    "\n",
    "sns.histplot(df['Amount'], bins=50, ax=ax[1], color='red', kde=True)\n",
    "ax[1].set_title('Distribution of Transaction Amount')\n",
    "ax[1].set_yscale('log')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Correlation Matrix"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.figure(figsize=(12, 10))\n",
    "corr = df.corr()\n",
    "sns.heatmap(corr, cmap='coolwarm_r', annot_kws={'size':20})\n",
    "plt.title('Feature Correlation Heatmap')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "**Conclusion:** Most V-features are entirely uncorrelated with each other (as expected from a PCA transformation). `Amount` and `Time` show some correlations with certain V-features, and `Class` is strongly negatively correlated with features like V14, V12, and V17."
   ]
  }
 ],
